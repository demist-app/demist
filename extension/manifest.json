{
  "manifest_version": 3,
  "name": "Demist",
  "version": "2.0.0",
  "description": "Real-time term definitions during any lecture, working like Grammarly, right where you are",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "https://demist.app/*",
        "https://*.demist.app/*",
        "*://localhost:*/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Demist"
  }
}
